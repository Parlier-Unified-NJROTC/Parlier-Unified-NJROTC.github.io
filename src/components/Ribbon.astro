---
interface Props {
  rlink: string;
  namelink: string;
  numberR: string;
}
const { rlink, namelink, numberR } = Astro.props;

// Style & JS
import "../style/box.css";
---

<div class="ribbon-option" id="ribbon-option">
  <img src={rlink} alt={numberR} />
  <label for={numberR}>{namelink}</label>
  <input type="checkbox" class="checkSwitch" id={numberR} name={numberR} />
  <select
    name="cool"
    class="ribbonSelect"
    style="background: none;border-radius: 25px;"
  >
    <option value="star-none">NONE</option>
    <option value="star-1bronze">Single Bronze</option>
    <option value="star-2bronze">Double Bronze</option>
    <option value="star-3bronze">Triple Bronze</option>
    <option value="star-4bronze">Quadruple Bronze</option>
    <option value="star-1sliver">Single Sliver</option>
    <option value="star-2sliver">Double Sliver</option>
    <option value="star-3sliver">Triple Sliver</option>
    <option value="star-4sliver">Quadruple Sliver</option>
    <option value="star-1gold">Single Gold</option>
    <option value="star-2gold">Double Gold</option>
    <option value="star-3gold">Triple Gold</option>
    <option value="star-4gold">Quadruple Gold</option>
  </select>
</div>
