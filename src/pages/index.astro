---
import Layout from "../layouts/Layout.astro";
import Rolling from "../components/Rolling.astro";

// Style & JS
import "../style/home.css";
---

<Layout title="Parlier Unified" subtitle="NJROTC">
    <Rolling />
        <div class="container">
            <div class="links-grid">
                <a href="/parents/" class="photo-card">
                    <div class="photo-container">
                        <img src="/Photo/IMG_3.jpeg" alt="Parents" class="photo-image" />
                        <div class="photo-overlay">
                            <h3 class="photo-title">Parents</h3>
                            <p class="photo-description">Resources and information for parents of NJROTC cadets</p>
                        </div>
                    </div>
                </a>
                <a href="/cadet/" class="photo-card">
                    <div class="photo-container">
                        <img src="/Photo/IMG_1.jpeg" alt="Cadets" class="photo-image" />
                        <div class="photo-overlay">
                            <h3 class="photo-title">Cadets</h3>
                            <p class="photo-description">Training materials, knowledge base, and cadet resources</p>
                        </div>
                    </div>
                </a>
                <a href="/calendar/" class="photo-card">
                    <div class="photo-container">
                        <img src="/Photo/IMG_2.jpeg" alt="Calendar" class="photo-image" />
                        <div class="photo-overlay">
                            <h3 class="photo-title">Calendar</h3>
                            <p class="photo-description">Upcoming events, drills, and important dates</p>
                        </div>
                    </div>
                </a>
            </div>
        </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const photoCards = document.querySelectorAll('.photo-card');
            
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('in-view');
                    }
                });
            }, {
                threshold: 0.1,
                rootMargin: '0px 0px -50px 0px'
            });
            
            photoCards.forEach(card => {
                observer.observe(card);
            });
        });
    </script>
</Layout>