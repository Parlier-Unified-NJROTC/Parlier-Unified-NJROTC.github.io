---
import Layout from "../../../layouts/Layout.astro";

// Style & JS
import "../../../style/instructor.css";
---

<Layout title="Instructors" subtitle="Parlier High School NJROTC" disableHero>
<div class="BG555">
    <div class="container">
        <div class="section-header">
            <h1 class="section-title">Our Instructors</h1>
            <p class="section-subtitle">Dedicated Leaders Shaping Future Leaders</p>
        </div>

        <!-- Section -->
        <div class="instructor-section">
            <div class="instructor-content">
                <div class="instructor-text">
                    <h2 class="instructor-name">N/A</h2>
                    <p class="instructor-bio">
                        N/A
                    </p>
                </div>
                <div class="instructor-image">
                    <div class="image-placeholder">
                        <svg width="80" height="80" viewBox="0 0 24 24" fill="#e6b220">
                            <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                        </svg>
                            <span> Photo</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Petty Officer Lowry Section -->
        <div class="instructor-section">
            <div class="instructor-content reverse">
                <div class="instructor-text">
                    <h2 class="instructor-name">Petty Officer Lowry</h2>
                    <p class="instructor-bio">
                        Petty Officer Lowry serves as an Instructor for the Parlier High School NJROTC Program. 
                        A proud U.S. Navy veteran, Petty Officer Lowry served as a Master at Arms, where he developed 
                        expertise in leadership, security, and mentorship. His time in the Navy instilled in him the 
                        values of Honor, Courage, and Commitment, which continue to guide his teaching and leadership today.
                    </p>
                    <p class="instructor-bio">
                        With years of experience in both education and coaching, Petty Officer Lowry is dedicated to 
                        shaping young men and women into confident, disciplined, and service minded citizens. He believes 
                        that true leadership begins with character and is measured by one's willingness to serve others.
                    </p>
                    <p class="instructor-bio">
                        At Parlier High School, Petty Officer Lowry combines his military experience and passion for 
                        education to build a culture of excellence within the NJROTC program. He is proud to represent 
                        both the Navy tradition and the Panther pride of Parlier High School, inspiring cadets to lead 
                        with integrity and purpose in everything they do.
                    </p>
                </div>
                <div class="instructor-image">
                    <div class="image-placeholder">
                        <svg width="80" height="80" viewBox="0 0 24 24" fill="#e6b220">
                            <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                        </svg>
                        <span>Petty Officer Lowry Photo</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</Layout>