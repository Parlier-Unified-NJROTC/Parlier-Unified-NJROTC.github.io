---
import Layout from "../../layouts/Layout.astro";
    
// Style & JS
import "../../style/about.css";
---

<Layout title="About" disableHero >
<div class="BG555">
    <div class="container">
        <div class="section-header">
            <h1 class="section-title">Contact Information</h1>
            <p class="section-subtitle">Get in touch with us through the following channels</p>
        </div>
        
        <div class="contact-card">
            <div class="card-overlay"></div>
            <div class="contact-content">
                <div class="contact-item email">
                    <div class="contact-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="white">
                            <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
                        </svg>
                    </div>
                    <div class="contact-details">
                        <div class="contact-label">Email Address</div>
                        <div class="contact-value">Placeholder@email.com</div>
                    </div>
                </div>
                
                <div class="contact-item room">
                    <div class="contact-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="white">
                            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                        </svg>
                    </div>
                    <div class="contact-details">
                        <div class="contact-label">Location</div>
                        <div class="contact-value">601 3rd St, Parlier, CA 93648, Room 53</div>
                    </div>
                </div>
                
                <div class="contact-item socials">
                    <div class="contact-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="white">
                            <path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92 1.61 0 2.92-1.31 2.92-2.92s-1.31-2.92-2.92-2.92z"/>
                        </svg>
                    </div>
                    <div class="contact-details">
                        <div class="contact-label">Connect With Us</div>
                        <div class="social-icons">
                            <!--
                            <a href="#" class="social-icon tiktok" title="TikTok">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="white">
                                    <path d="M19.589 6.686a4.793 4.793 0 0 1-3.77-4.245V2h-3.445v13.672a2.896 2.896 0 0 1-5.201 1.743l-.002-.001.002.001a2.895 2.895 0 0 1 3.183-4.51v-3.5a6.329 6.329 0 0 0-5.394 10.692 6.33 6.33 0 0 0 10.857-4.424V8.687a8.182 8.182 0 0 0 4.773 1.526V6.79a4.831 4.831 0 0 1-1.003-.104z"/>
                                </svg>
                            </a> 
                            -->
                            <a href="https://www.instagram.com/parlier_njrotc/" class="social-icon instagram" title="Instagram">
