---

import { getCollection } from 'astro:content';
import Layout from "../../layouts/Layout.astro";
const departments = await getCollection('departments');

const {frontmatter} = Astro.props;
    
// Style & JS
import "../../style/department.less";
---

<Layout disableHero title="Departments" fancyBackground>
<section class="departments">
    <div class="departments-container">
        <div class="section-header">
            <h2 class="section-title">Our Departments</h2>
            <p class="section-subtitle">Discover our specialized teams dedicated to excellence</p>
        </div>
        <div class="departments-grid">
            {departments.map(department => (
                <div class="department-card" >
                    <a href={`/departments/${department.id}`} class="department-link">
                        <div class="card-overlay"></div>
                        <div class="department-icon" style={{ backgroundImage: `url(${department.data.img})` }}>
                            <div class="icon-overlay"></div>
                        </div>
                        <div class="department-content">
                            <div class="content-wrapper">
                                <h3 class="department-name">{department.data.name}</h3>
                                <p class="department-description">
                                    {department.data.description}
                                </p>
                                <div class="department-footer">
                                    <span class="department-button">
                                        LEARN MORE
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            ))}
        </div>
    </div>
</section>
</Layout>
