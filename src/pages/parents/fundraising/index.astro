---
import Layout from '../../../layouts/Layout.astro';

// Style & JS
import "../../../style/fundraising.css";
---

<Layout title="Fundraising" disableHero>
<div class="BG555">
    <div class="container">
        <div class="section-header">
            <h1 class="section-title">Fundraising & Donations</h1>
            <p class="section-subtitle">Supporting Our Cadets' Success</p>
        </div>

        <div class="content-card">
            <div class="card-overlay"></div>
            <div class="content-wrapper">
                <section class="donate-section">
                    <div class="donate-content">
                        <p>If you would like to make a donation to the Unit simply write a check payable to <strong>Parlier NJROTC</strong> and mail it to:</p>
                        
                        <div class="address-card">
                            <div class="address-icon">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="#e6b220">
                                    <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                                </svg>
                            </div>
                            <address class="donation-address">
                                <strong>Parlier High School NJROTC</strong><br />
                                603 3rd St<br />
                                Parlier, CA 93648
                            </address>
                        </div>

                        <div class="note-box">
                            <div class="note-icon">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="#e6b220">
                                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
                                </svg>
                            </div>
                            <p class="note" style="text-align: left;">Please include your name (if applicable) and a short note so we can apply funds appropriately.</p>
                        </div>
                    </div>
                </section>

                <section class="thanks-section">
                    <div class="thanks-header">
                        <h2 class="thanks-title">Thank You</h2>
                        <div class="heart-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="#e6b220">
                                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                            </svg>
                        </div>
                    </div>
                    <p class="thanks-message">Your support helps provide fleidtrips, equipment, and opportunities for our cadets. Every contribution big or small makes a real difference in their development and success. We deeply appreciate your generosity and involvement in our program.</p>
                </section>
            </div>
        </div>
    </div>
</div>
</Layout>