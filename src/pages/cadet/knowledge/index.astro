---
import Layout from "../../../layouts/Layout.astro";

// Style & JS
import "../../../style/knowledge.css";
---

<Layout title="Cadet Knowledge" disableHero>
<div class="BG555">
    <div class="container">
        <div class="section-header">
            <h1 class="section-title">Cadet Knowledge</h1>
            <p class="section-subtitle">
                "Important information needed for all your years in NJ"<br>
                Search in your cadet field manual (B.O.B.) for more information. In the 
                <a href="#PDF" class="manual-link">NJROTC Manual's</a>
            </p>
        </div>

        <div class="years-grid">
            <!-- Freshman - NS1 -->
            <div class="year-section">
                <div class="year-header freshman">
                    <h2 class="year-title">Freshman - NS1</h2>
                </div>
                <div class="material-grid">
                    <a class="study-card" href="/cadet/knowledge/orders/">
                        <div class="card-content">
                            <h3 class="card-title">General Orders</h3>
                            <p class="card-desc">"The rules you follow while being in the NJROTC"</p>
                        </div>
                    </a>
                    <a class="study-card" id="PDF" href="/cadet/manuals">
                        <div class="card-content">
                            <h3 class="card-title">The NJROTC Manual's</h3>
                        </div>
                    </a>
                    <a class="study-card" href="/cadet/knowledge/chain/">
                        <div class="card-content">
                            <h3 class="card-title">Chain of Command</h3>
                            <p class="card-desc">"Who is incharge of what"</p>
                        </div>
                    </a>
                </div>
            </div>

            <!-- Sophomore - NS2 -->
            <div class="year-section">
                <div class="year-header sophomore">
                    <h2 class="year-title">Sophomore - NS2</h2>
                </div>
                <div class="material-grid">
                    <a class="study-card" href="/cadet/knowledge/ranks/">
                        <div class="card-content">
                            <h3 class="card-title">Navy Ranks</h3>
                            <p class="card-desc">"How Knowledgable are you?"</p>
                        </div>
                    </a>
                    <a class="study-card" href="https://quizlet.com/893894016/navy-and-njrotc-ranks-flash-cards/?funnelUUID=1c12c3d0-e490-45d7-a18b-c0252f125790" target="_blank">
                        <div class="card-content">
                            <h3 class="card-title">Navy Ranks Flashcards</h3>
                            <p class="card-desc">(QUIZLET)</p>
                        </div>
                    </a>
                    <a class="study-card" href="/cadet/tool/flashcard/navy/">
                        <div class="card-content">
                            <h3 class="card-title">Navy Ranks Flashcards</h3>
                            <p class="card-desc">"Study up on rank knowledge"</p>
                        </div>
                    </a>
                    <a class="study-card" href="/cadet/knowledge/alphabet/">
                        <div class="card-content">
                            <h3 class="card-title">Military Alphabet</h3>
                            <p class="card-desc">"X Y and Z now I know my ABCs."</p>
                        </div>
                    </a>
                    <a class="study-card" href="https://quizlet.com/894014603/flashcards?funnelUUID=a0228bd3-785d-46f0-b1e4-42333b3a9fa2" target="_blank">
                        <div class="card-content">
                            <h3 class="card-title">Chain of Command Flashcards</h3>
                            <p class="card-desc">(QUIZLET)</p>
                        </div>
                    </a>
                    <a class="study-card" href="/cadet/tool/flashcard/chain/">
                        <div class="card-content">
                            <h3 class="card-title">Chain of Command Flashcards</h3>
                        </div>
                    </a>
                    <div class="additional-info">
                        <p>+ The NJROTC Manual's</p>
                        <p>+ AMI uniform questions</p>
                        <p>+ Chain of command</p>
                        <p>+ General orders</p>
                        <p>+ Officer Sleeves</p>
                    </div>
                </div>
            </div>

            <!-- Junior - NS3 -->
            <div class="year-section">
                <div class="year-header junior">
                    <h2 class="year-title">Junior - NS3</h2>
                </div>
                <div class="material-grid">
                    <a class="study-card" href="/cadet/tool/flashcard/ami/">
                        <div class="card-content">
                            <h3 class="card-title">AMI Questions Flashcards</h3>
                        </div>
                    </a>
                    <a class="study-card" href="https://quizlet.com/notes/njrotc-uniform-regulations-d760c639-fa2f-4b83-93a7-c30bf4491f34" target="_blank">
                        <div class="card-content">
                            <h3 class="card-title">AMI Questions Flashcards</h3>
                            <p class="card-desc">(QUIZLET)</p>
                        </div>
                    </a>
                    <a class="study-card" href="/cadet/tool/flashcard/abc/">
                        <div class="card-content">
                            <h3 class="card-title">Military Alphabet Flashcards</h3>
                        </div>
                    </a>
                    <a class="study-card" href="https://quizlet.com/894017921/military-alphabet-flash-cards/?new" target="_blank">
                        <div class="card-content">
                            <h3 class="card-title">Military Alphabet Flashcards</h3>
                            <p class="card-desc">(QUIZLET)</p>
                        </div>
                    </a>
                    <div class="additional-info">
                        <p>+ The NJROTC Manual's</p>
                        <p>+ AMI questions</p>
                        <p>+ Navy Ranks</p>
                        <p>+ Military Alphabet & flags</p>
                        <p>+ AMI uniform questions</p>
                        <p>+ Chain of Command</p>
                        <p>+ General Orders</p>
                    </div>
                </div>
            </div>

            <!-- Senior - NS4 -->
            <div class="year-section">
                <div class="year-header senior">
                    <h2 class="year-title">Senior - NS4</h2>
                </div>
                <div class="material-grid">
                    <a class="study-card" href="https://www.cnn.com/world" target="_blank">
                        <div class="card-content">
                            <h3 class="card-title">Current Events</h3>
                            <p class="card-desc">Links to CNN - "All events happening here on planet earth"</p>
                        </div>
                    </a>
                    <div class="additional-info">
                        <p>+ Everything from previous years</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</Layout>