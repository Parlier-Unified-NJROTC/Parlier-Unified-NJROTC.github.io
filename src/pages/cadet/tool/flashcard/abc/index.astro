---
import Layout from "../../../../../layouts/Layout.astro";

// Style & JS
import "../../../../../style/fc.css";
---

<Layout title="Military Alphabet" disableHero>
    <section class="flashcard-section">
        <div id="FlashCard-BG">
            <div class="card-counter" id="cardCounter">Card 1 of 15</div>

            <div class="container444">
                <div class="flashcard">
                    <div class="front"></div>
                    <div class="back" style="transform: rotateX(180deg);"></div>
                </div>
            </div>

            <div class="progress-bar">
                <div class="progress"></div>
            </div>

            <div class="navigation">
                <button onclick="prevCard()">Previous</button>
                <button onclick="scrambleCards()">Scramble</button>
                <button onclick="nextCard()">Next</button>
            </div>
        </div>
    </section>
    <script lang="js">
        const flashcards = [
            { front: "'A' Military Alphabet", back: "Alpha" },
            { front: "'B' Military Alphabet", back: "Bravo" },
            { front: "'C' Military Alphabet", back: "Charlie" },
            { front: "'D' Military Alphabet", back: "Delta" },
            { front: "'E' Military Alphabet", back: "Echo" },
            { front: "'F' Military Alphabet", back: "Foxtrot" },
            { front: "'G' Military Alphabet", back: "Golf" },
            { front: "'H' Military Alphabet", back: "Hotel" },
            { front: "'I' Military Alphabet", back: "India" },
            { front: "'J' Military Alphabet", back: "Juliett" },
            { front: "'K' Military Alphabet", back: "Kilo" },
            { front: "'L' Military Alphabet", back: "Lima" },
            { front: "'M' Military Alphabet", back: "Mike" },
            { front: "'N' Military Alphabet", back: "November" },
            { front: "'O' Military Alphabet", back: "Oscar" },
            { front: "'P' Military Alphabet", back: "Papa" },
            { front: "'Q' Military Alphabet", back: "Quebec" },
            { front: "'R' Military Alphabet", back: "Romeo" },
            { front: "'S' Military Alphabet", back: "Sierra" },
            { front: "'T' Military Alphabet", back: "Tango" },
            { front: "'U' Military Alphabet", back: "Uniform" },
            { front: "'V' Military Alphabet", back: "Victor" },
            { front: "'W' Military Alphabet", back: "Whiskey" },
            { front: "'X' Military Alphabet", back: "X-ray" },
            { front: "'Y' Military Alphabet", back: "Yankee" },
            { front: "'Z' Military Alphabet", back: "Zulu" },
        ];

        let currentFlashcards = [...flashcards];
        let currentCardIndex = 0;
        let isCooldown = false;
        const container444 = document.querySelector(".container444");
        const progress = document.querySelector(".progress");
        const flashcard = document.querySelector(".flashcard");
        const cardCounter = document.getElementById("cardCounter");

        function updateProgress() {
            const progressWidth =
                ((currentCardIndex + 1) / currentFlashcards.length) * 100;
            progress.style.width = `${progressWidth}%`;
            cardCounter.textContent = `Card ${currentCardIndex + 1} of ${currentFlashcards.length}`;
        }

        function updateCard() {
            flashcard.classList.remove("flipped");
            setTimeout(() => {
                const card = currentFlashcards[currentCardIndex];
                container444.querySelector(".front").textContent = card.front;
                container444.querySelector(".back").textContent = card.back;
                updateProgress();
            }, 150);
        }

        function flipCard() {
            flashcard.classList.toggle("flipped");
        }

        function scrambleCards() {
            const shuffled = [...flashcards];
            for (let i = shuffled.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
            }
            currentFlashcards = shuffled;
            currentCardIndex = 0;
            updateCard();
        }

        function nextCard() {
            if (currentCardIndex < currentFlashcards.length - 1) {
                currentCardIndex++;
                updateCard();
            }
        }

        function prevCard() {
            if (currentCardIndex > 0) {
                currentCardIndex--;
                updateCard();
            }
        }

        document.addEventListener("keydown", (e) => {
            if (e.code === "Space" && !isCooldown) {
                flipCard();
                isCooldown = true;
                setTimeout(() => {
                    isCooldown = false;
                }, 600);
            } else if (e.key === "ArrowRight") {
                nextCard();
            } else if (e.key === "ArrowLeft") {
                prevCard();
            }
        });

        flashcard.addEventListener("click", flipCard);
        updateProgress();
        updateCard();

        window.addEventListener("keydown", function (e) {
            if (e.keyCode == 32 && e.target == document.body) {
                e.preventDefault();
            }
        });
    </script>
</Layout>
