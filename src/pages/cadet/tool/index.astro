---
import Layout from '../../../layouts/Layout.astro';

// Style & JS
import "../../../style/tools.css";
---

<Layout title="Tools" disableHero>
<div class="BG555">
    <div class="container">
        <!-- Hero Section -->
        <div class="section-header">
            <h1 class="section-title">Tools</h1>
            <p class="section-subtitle">Explore our collection of useful tools for cadets.</p>
        </div>

        <!-- Resource Cards -->
        <div class="resources-section">
            <div class="card-grid">
                <a class="res-card" href="/cadet/tool/ribbon">
                    <div class="card-icon">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="#e6b220">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2zm0 2v12h16V6H4zm2 "/>
                        </svg>
                    </div>
                    <div class="card-content">
                        <h3 class="card-title">Ribbon Builder</h3>
                        <p class="card-desc">Build and visualize your ribbon rack with our interactive ribbon builder tool.</p>
                    </div>
                </a>

                <a class="res-card" href="/cadet/tool/flashcard">
                    <div class="card-icon">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="#e6b220">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2zm0 2v12h16V6H4zm2 2h12v2H6V8zm0 4h12v2H6v-2z"/>
                        </svg>
                    </div>
                    <div class="card-content">
                        <h3 class="card-title">Flashcards</h3>
                        <p class="card-desc">Interactive flashcards to help you study and memorize important information.</p>
                    </div>
                </a>
            </div>
        </div>

	</div>
</div>
</div>
</Layout>