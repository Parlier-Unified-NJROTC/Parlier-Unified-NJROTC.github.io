---
import Layout from "../../../layouts/Layout.astro";

// Style & JS
import "../../../style/help.css";
---

<Layout title="NJROTC Help Center" disableHero>
    <head>
        <!-- Material Icons -->
        <link
            href="https://fonts.googleapis.com/icon?family=Material+Icons"
            rel="stylesheet"
        />
    </head>
    <div class="BG555">
        <div class="container">
            <div class="header">
                <h1>NJROTC Help Center</h1>
                <p>Submit program signups or suggestions for improvement.</p>
            </div>

            <div class="tab-container">
                <div class="tab-scroll-container">
                    <div class="tab-headers">
                        <button class="tab-header active" data-tab="suggestion">
                            <span class="material-icons tab-icon"
                                >lightbulb</span
                            >
                            Suggestion Box
                        </button>
                        <button class="tab-header" data-tab="signup">
                            <span class="material-icons tab-icon"
                                >person_add</span
                            >
                            Signup Form
                        </button>
                    </div>
                    <div class="tab-indicator" id="tabIndicator"></div>
                </div>

                <div class="tab-contents">
                    <!-- Suggestion Form -->
                    <div class="tab-content active" id="suggestion-content">
                        <h2>Suggestion Box</h2>
                        <form id="suggestionForm">
                            <div class="form-group">
                                <label for="suggestionType"
                                    >Suggestion Type *</label
                                >
                                <div
                                    class="custom-select"
                                    id="suggestionCustomSelect"
                                    aria-label="Select Type"
                                >
                                    <select
                                        class="hidden-native"
                                        id="suggestionType"
                                        name="type"
                                        required
                                    >
                                        <option value="">Select Type</option>
                                        <option value="Website Bug" selected
                                            >Website Bug</option
                                        >
                                        <option value="Website Improvement"
                                            >Website Improvement</option
                                        >
                                        <option value="Event Idea"
                                            >Event Idea</option
                                        >
                                        <option value="Program Suggestion"
                                            >Program Suggestion</option
                                        >
                                        <option value="Other">Other</option>
                                    </select>

                                    <button
                                        class="select-face"
                                        id="suggestionSelectFace"
                                        type="button"
                                        aria-haspopup="listbox"
                                        aria-expanded="false"
                                    >
                                        <span
                                            class="title"
                                            id="suggestionSelectedLabel"
                                        >
                                            Website Bug
                                        </span>
                                        <span class="arrow" aria-hidden="true"
                                        ></span>
                                    </button>

                                    <div
                                        class="dropdowns"
                                        id="suggestiondropdowns"
                                        role="listbox"
                                        aria-label="Options"
                                    >
                                        <div
                                            class="option"
                                            data-value="Website Bug"
                                            tabindex="0"
                                        >
                                            Website Bug
                                        </div>
                                        <div
                                            class="option"
                                            data-value="Website Improvement"
                                            tabindex="0"
                                        >
                                            Website Improvement
                                        </div>
                                        <div
                                            class="option"
                                            data-value="Event Idea"
                                            tabindex="0"
                                        >
                                            Event Idea
                                        </div>
                                        <div
                                            class="option"
                                            data-value="Program Suggestion"
                                            tabindex="0"
                                        >
                                            Program Suggestion
                                        </div>
                                        <div
                                            class="option"
                                            data-value="Other"
                                            tabindex="0"
                                        >
                                            Other
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <label for="suggestionText"
                                    >Your Suggestion *</label
                                >
                                <textarea
                                    id="suggestionText"
                                    name="suggestion"
                                    class="form-control"
                                    placeholder="Please describe your suggestion in detail..."
                                    rows="6"
                                    required></textarea>
                            </div>

                            <div class="status-message" id="suggestionStatus">
                            </div>

                            <button
                                type="submit"
                                class="submit-btn"
                                id="suggestionSubmit"
                            >
                                <span id="suggestionBtnText"
                                    >Submit Suggestion</span
                                >
                                <div
                                    class="loading"
                                    id="suggestionLoading"
                                    style="display: none;"
                                >
                                </div>
                            </button>
                        </form>
                    </div>

                    <!-- Signup Form -->
                    <div class="tab-content" id="signup-content">
                        <h2>Program Signup</h2>
                        <form id="signupForm">
                            <div class="form-group">
                                <label for="fullName">Full Name *</label>
                                <input
                                    type="text"
                                    id="fullName"
                                    name="fullName"
                                    class="form-control"
                                    placeholder="Enter your full name"
                                    required
                                />
                            </div>

                            <div class="form-group">
                                <label for="schoolId">Student ID *</label>
                                <input
                                    type="text"
                                    id="schoolId"
                                    name="schoolId"
                                    class="form-control"
                                    placeholder="Enter your student ID"
                                    required
                                />
                            </div>

                            <div class="form-group">
                                <label for="grade">Grade Level *</label>
                                <div
                                    class="custom-select"
                                    id="gradeCustomSelect"
                                    aria-label="Select Grade"
                                >
                                    <select
                                        class="hidden-native"
                                        id="grade"
                                        name="grade"
                                        required
                                    >
                                        <option value="">Select Grade</option>
                                        <option value="9">9th Grade</option>
                                        <option value="10">10th Grade</option>
                                        <option value="11">11th Grade</option>
                                        <option value="12">12th Grade</option>
                                    </select>

                                    <button
                                        class="select-face"
                                        id="gradeSelectFace"
                                        type="button"
                                        aria-haspopup="listbox"
                                        aria-expanded="false"
                                    >
                                        <span
                                            class="title"
                                            id="gradeSelectedLabel"
                                        >
                                            Select Grade
                                        </span>
                                        <span class="arrow" aria-hidden="true"
                                        ></span>
                                    </button>

                                    <div
                                        class="dropdowns"
                                        id="gradedropdowns"
                                        role="listbox"
                                        aria-label="Grade Options"
                                    >
                                        <div
                                            class="option"
                                            data-value="9"
                                            tabindex="0"
                                        >
                                            9th Grade
                                        </div>
                                        <div
                                            class="option"
                                            data-value="10"
                                            tabindex="0"
                                        >
                                            10th Grade
                                        </div>
                                        <div
                                            class="option"
                                            data-value="11"
                                            tabindex="0"
                                        >
                                            11th Grade
                                        </div>
                                        <div
                                            class="option"
                                            data-value="12"
                                            tabindex="0"
                                        >
                                            12th Grade
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <label for="email">Email Address *</label>
                                <input
                                    type="email"
                                    id="email"
                                    name="email"
                                    class="form-control"
                                    placeholder="Enter your email"
                                    required
                                />
                            </div>

                            <div class="form-group">
                                <label for="reason"
                                    >Why do you want to join NJROTC? *</label
                                >
                                <textarea
                                    id="reason"
                                    name="reason"
                                    class="form-control"
                                    placeholder="Please tell us why you're interested in joining the NJROTC program..."
                                    rows="4"
                                    required></textarea>
                            </div>

                            <div class="status-message" id="signupStatus"></div>

                            <button
                                type="submit"
                                class="submit-btn"
                                id="signupSubmit"
                            >
                                <span id="signupBtnText">Submit Signup</span>
                                <div
                                    class="loading"
                                    id="signupLoading"
                                    style="display: none;"
                                >
                                </div>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script lang="">
        const API_BASE_URL =
            "https://parlier-unified-njrotc-server.onrender.com";

        document.addEventListener("DOMContentLoaded", function () {
            const fadeAnimations = {};

            function adddropdownsAnimations(dropdowns) {
                let fadeOutTimer;

                function fadeIn() {
                    clearTimeout(fadeOutTimer);
                    dropdowns.style.transition = "opacity 0.15s ease-in";
                    dropdowns.style.opacity = "1";
                    dropdowns.style.display = "block";
                }

                function fadeOut() {
                    dropdowns.style.transition = "opacity 250ms ease-out";
                    dropdowns.style.opacity = "0";
                    fadeOutTimer = setTimeout(() => {
                        dropdowns.style.display = "none";
                        dropdowns.style.transition = "";
                    }, 250);
                }

                return { fadeIn, fadeOut };
            }

            const tabHeaders = document.querySelectorAll(".tab-header");
            const tabContents = document.querySelectorAll(".tab-content");
            const tabIndicator = document.getElementById("tabIndicator");
            const tabHeadersContainer = document.querySelector(".tab-headers");
            const signupForm = document.getElementById("signupForm");
            const suggestionForm = document.getElementById("suggestionForm");
            const scrollArrows = document.querySelectorAll(".tab-scroll-arrow");
            scrollArrows.forEach((arrow) => (arrow.style.display = "none"));

            let resizeTimeout;
            let isResizing = false;

            function updateTabIndicator() {
                const activeTab = document.querySelector(".tab-header.active");
                if (!activeTab) return;

                void activeTab.offsetWidth;

                const tabRect = activeTab.getBoundingClientRect();
                const containerRect =
                    tabHeadersContainer.getBoundingClientRect();

                const left = tabRect.left - containerRect.left;
                const width = tabRect.width;

                requestAnimationFrame(() => {
                    tabIndicator.style.width = `${width}px`;
                    tabIndicator.style.left = `${left}px`;
                    tabIndicator.style.opacity = "1";
                });
            }

            updateTabIndicator();
            setTimeout(updateTabIndicator, 100);

            function switchTab(tabName) {
                window.location.hash = tabName;
                tabHeaders.forEach((header) => {
                    if (header.dataset.tab === tabName) {
                        header.classList.add("active");
                    } else {
                        header.classList.remove("active");
                    }
                });

                tabContents.forEach((content) => {
                    if (content.id === `${tabName}-content`) {
                        content.classList.add("active");
                    } else {
                        content.classList.remove("active");
                    }
                });

                setTimeout(updateTabIndicator, 10);
            }

            tabHeaders.forEach((header) => {
                header.addEventListener("click", function () {
                    const tabName = this.dataset.tab;
                    switchTab(tabName);
                });
            });

            function checkHash() {
                const hash = window.location.hash.substring(1).toLowerCase();
                if (hash === "signup") {
                    switchTab("signup");
                } else if (hash === "suggestion") {
                    switchTab("suggestion");
                } else {
                    switchTab("suggestion");
                }
            }

            checkHash();

            window.addEventListener("hashchange", checkHash);

            window.addEventListener("resize", function () {
                isResizing = true;

                tabIndicator.style.opacity = "0";

                clearTimeout(resizeTimeout);
                resizeTimeout = setTimeout(function () {
                    updateTabIndicator();
                    isResizing = false;
                }, 150);
            });
            window.addEventListener("orientationchange", function () {
                setTimeout(updateTabIndicator, 300);
            });

            document.addEventListener("transitionend", function (e) {
                if (e.target.classList.contains("tab-header")) {
                    updateTabIndicator();
                }
            });

            let touchStartX = 0;
            let touchStartY = 0;
            let touchEndX = 0;
            let touchEndY = 0;

            document.addEventListener(
                "touchstart",
                function (e) {
                    touchStartX = e.changedTouches[0].screenX;
                    touchStartY = e.changedTouches[0].screenY;
                },
                { passive: true },
            );

            document.addEventListener(
                "touchend",
                function (e) {
                    touchEndX = e.changedTouches[0].screenX;
                    touchEndY = e.changedTouches[0].screenY;
                    handleSwipe();
                },
                { passive: true },
            );

            function handleSwipe() {
                const minSwipeDistance = 50;
                const horizontalSwipe = Math.abs(touchEndX - touchStartX);
                const verticalSwipe = Math.abs(touchEndY - touchStartY);

                if (
                    horizontalSwipe > verticalSwipe &&
                    horizontalSwipe > minSwipeDistance
                ) {
                    const currentTab =
                        document.querySelector(".tab-header.active").dataset
                            .tab;

                    if (touchEndX < touchStartX) {
                        if (currentTab === "suggestion") {
                            switchTab("signup");
                        }
                    } else {
                        if (currentTab === "signup") {
                            switchTab("suggestion");
                        }
                    }
                }
            }

            function validateEmail(email) {
                const re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                return re.test(email);
            }

            function showStatus(element, message, isSuccess) {
                element.textContent = message;
                element.className = `status-message ${isSuccess ? "success" : "error"}`;
                element.style.display = "block";

                setTimeout(() => {
                    element.scrollIntoView({
                        behavior: "smooth",
                        block: "nearest",
                    });
                }, 100);
            }

            // Suggestion dropdowns with Fade Animations
            const suggestionNativeSelect =
                document.getElementById("suggestionType");
            if (suggestionNativeSelect) {
                const selectFace = document.getElementById(
                    "suggestionSelectFace",
                );
                const dropdowns = document.getElementById("suggestiondropdowns");
                const arrow = document.querySelector(".arrow");
                const selectedLabel = document.getElementById(
                    "suggestionSelectedLabel",
                );
                const options = Array.from(
                    dropdowns.querySelectorAll(".option"),
                );

                // Add animations for this dropdowns
                fadeAnimations.suggestion = adddropdownsAnimations(dropdowns);

                function setActiveFromValue(value) {
                    options.forEach((opt) => {
                        opt.classList.toggle(
                            "active",
                            opt.dataset.value === value,
                        );
                    });
                    selectedLabel.textContent = value || "Select Type";
                }

                function opendropdowns() {
                    fadeAnimations.suggestion.fadeIn();
                    arrow.style.transform = "rotate(180deg)";
                    selectFace.setAttribute("aria-expanded", "true");
                }

                function closedropdowns() {
                    fadeAnimations.suggestion.fadeOut();
                    arrow.style.transform = "rotate(0deg)";
                    selectFace.setAttribute("aria-expanded", "false");
                }

                let open = false;
                function toggledropdowns() {
                    open = !open;
                    if (open) {
                        opendropdowns();
                    } else {
                        closedropdowns();
                    }
                }

                selectFace.addEventListener("click", (e) => {
                    e.stopPropagation();
                    toggledropdowns();
                });

                options.forEach((opt) => {
                    opt.addEventListener("click", (e) => {
                        const value = e.currentTarget.dataset.value;
                        setActiveFromValue(value);
                        suggestionNativeSelect.value = value;
                        closedropdowns();
                        open = false;

                        suggestionNativeSelect.dispatchEvent(
                            new Event("change", { bubbles: true }),
                        );
                    });
                    opt.addEventListener("keydown", (e) => {
                        if (e.key === "Enter" || e.key === " ") {
                            e.preventDefault();
                            const value = e.currentTarget.dataset.value;
                            setActiveFromValue(value);
                            suggestionNativeSelect.value = value;
                            closedropdowns();
                            open = false;

                            suggestionNativeSelect.dispatchEvent(
                                new Event("change", { bubbles: true }),
                            );
                        }
                    });
                });

                document.addEventListener("keydown", (e) => {
                    if (!open) return;
                    const current = options.findIndex((o) =>
                        o.classList.contains("active"),
                    );
                    let idx = current >= 0 ? current : -1;

                    if (e.key === "ArrowDown") {
                        e.preventDefault();
                        idx = (idx + 1) % options.length;
                        options.forEach((o) => o.classList.remove("active"));
                        options[idx].classList.add("active");
                        options[idx].focus();
                    } else if (e.key === "ArrowUp") {
                        e.preventDefault();
                        idx = (idx - 1 + options.length) % options.length;
                        options.forEach((o) => o.classList.remove("active"));
                        options[idx].classList.add("active");
                        options[idx].focus();
                    } else if (e.key === "Escape") {
                        closedropdowns();
                        open = false;
                    }
                });

                document.addEventListener("click", (e) => {
                    const customSelect = document.getElementById(
                        "suggestionCustomSelect",
                    );
                    if (customSelect && !customSelect.contains(e.target)) {
                        closedropdowns();
                        open = false;
                    }
                });

                setActiveFromValue(
                    suggestionNativeSelect.value || "Website Bug",
                );
            }

            // Grade dropdowns with Fade Animations
            const gradeNativeSelect = document.getElementById("grade");
            if (gradeNativeSelect) {
                const gradeSelectFace =
                    document.getElementById("gradeSelectFace");
                const gradedropdowns = document.getElementById("gradedropdowns");
                const gradeArrow = gradeSelectFace.querySelector(".arrow");
                const gradeSelectedLabel =
                    document.getElementById("gradeSelectedLabel");
                const gradeOptions = Array.from(
                    gradedropdowns.querySelectorAll(".option"),
                );

                // Add animations for this dropdowns
                fadeAnimations.grade = adddropdownsAnimations(gradedropdowns);

                function setGradeActiveFromValue(value) {
                    gradeOptions.forEach((opt) => {
                        opt.classList.toggle(
                            "active",
                            opt.dataset.value === value,
                        );
                    });

                    const selectedOption = gradeOptions.find(
                        (opt) => opt.dataset.value === value,
                    );
                    gradeSelectedLabel.textContent = selectedOption
                        ? selectedOption.textContent
                        : "Select Grade";
                }

                function openGradedropdowns() {
                    fadeAnimations.grade.fadeIn();
                    gradeArrow.style.transform = "rotate(180deg)";
                    gradeSelectFace.setAttribute("aria-expanded", "true");
                }

                function closeGradedropdowns() {
                    fadeAnimations.grade.fadeOut();
                    gradeArrow.style.transform = "rotate(0deg)";
                    gradeSelectFace.setAttribute("aria-expanded", "false");
                }

                let gradeOpen = false;
                function toggleGradedropdowns() {
                    gradeOpen = !gradeOpen;
                    if (gradeOpen) {
                        openGradedropdowns();
                    } else {
                        closeGradedropdowns();
                    }
                }

                gradeSelectFace.addEventListener("click", (e) => {
                    e.stopPropagation();
                    toggleGradedropdowns();
                });

                gradeOptions.forEach((opt) => {
                    opt.addEventListener("click", (e) => {
                        const value = e.currentTarget.dataset.value;
                        setGradeActiveFromValue(value);
                        gradeNativeSelect.value = value;
                        closeGradedropdowns();
                        gradeOpen = false;

                        gradeNativeSelect.dispatchEvent(
                            new Event("change", { bubbles: true }),
                        );
                    });
                    opt.addEventListener("keydown", (e) => {
                        if (e.key === "Enter" || e.key === " ") {
                            e.preventDefault();
                            const value = e.currentTarget.dataset.value;
                            setGradeActiveFromValue(value);
                            gradeNativeSelect.value = value;
                            closeGradedropdowns();
                            gradeOpen = false;

                            gradeNativeSelect.dispatchEvent(
                                new Event("change", { bubbles: true }),
                            );
                        }
                    });
                });

                document.addEventListener("keydown", (e) => {
                    if (!gradeOpen) return;
                    const current = gradeOptions.findIndex((o) =>
                        o.classList.contains("active"),
                    );
                    let idx = current >= 0 ? current : -1;

                    if (e.key === "ArrowDown") {
                        e.preventDefault();
                        idx = (idx + 1) % gradeOptions.length;
                        gradeOptions.forEach((o) =>
                            o.classList.remove("active"),
                        );
                        gradeOptions[idx].classList.add("active");
                        gradeOptions[idx].focus();
                    } else if (e.key === "ArrowUp") {
                        e.preventDefault();
                        idx =
                            (idx - 1 + gradeOptions.length) %
                            gradeOptions.length;
                        gradeOptions.forEach((o) =>
                            o.classList.remove("active"),
                        );
                        gradeOptions[idx].classList.add("active");
                        gradeOptions[idx].focus();
                    } else if (e.key === "Escape") {
                        closeGradedropdowns();
                        gradeOpen = false;
                    }
                });

                document.addEventListener("click", (e) => {
                    const gradeCustomSelect =
                        document.getElementById("gradeCustomSelect");
                    if (
                        gradeCustomSelect &&
                        !gradeCustomSelect.contains(e.target)
                    ) {
                        closeGradedropdowns();
                        gradeOpen = false;
                    }
                });

                setGradeActiveFromValue("");
            }

            // Rest of your form submission code remains the same...
            signupForm.addEventListener("submit", async function (e) {
                e.preventDefault();

                const submitBtn = document.getElementById("signupSubmit");
                const btnText = document.getElementById("signupBtnText");
                const loading = document.getElementById("signupLoading");
                const status = document.getElementById("signupStatus");

                const fullName = document
                    .getElementById("fullName")
                    .value.trim();
                const schoolId = document
                    .getElementById("schoolId")
                    .value.trim();
                const grade = document.getElementById("grade").value;
                const email = document.getElementById("email").value.trim();
                const reason = document.getElementById("reason").value.trim();

                if (!fullName) {
                    showStatus(status, "Please enter your full name", false);
                    return;
                }

                if (!grade) {
                    showStatus(status, "Please select your grade level", false);
                    return;
                }

                if (!validateEmail(email)) {
                    showStatus(
                        status,
                        "Please enter a valid email address",
                        false,
                    );
                    return;
                }

                if (!reason || reason.length < 20) {
                    showStatus(
                        status,
                        "Please provide a meaningful reason for joining (at least 20 characters)",
                        false,
                    );
                    return;
                }

                btnText.style.display = "none";
                loading.style.display = "inline-block";
                submitBtn.disabled = true;
                status.style.display = "none";

                try {
                    const formData = {
                        fullName: fullName,
                        schoolId: schoolId,
                        grade: grade,
                        email: email,
                        reason: reason,
                    };
                    console.log("Sending signup request:", formData);
                    console.log("API URL:", `${API_BASE_URL}/api/signup`);

                    const response = await fetch(`${API_BASE_URL}/api/signup`, {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json",
                        },
                        body: JSON.stringify(formData),
                        mode: "cors",
                        credentials: "omit",
                    });

                    console.log("Response status:", response.status);

                    const result = await response.json();
                    console.log("Response data:", result);

                    if (response.ok) {
                        showStatus(
                            status,
                            "✓ Signup submitted successfully! Confirmation email sent.",
                            true,
                        );
                        signupForm.reset();

                        // Reset custom select after form reset
                        setGradeActiveFromValue("");

                        setTimeout(() => {
                            status.style.display = "none";
                        }, 5000);
                    } else {
                        throw new Error(
                            result.error ||
                                result.details ||
                                "Submission failed",
                        );
                    }
                } catch (error) {
                    console.error("Error:", error);
                    let errorMessage = error.message;
                    if (error.message.includes("Failed to fetch")) {
                        errorMessage =
                            "Cannot connect to server. Please check your internet connection or try again later.";
                    } else if (error.message.includes("NetworkError")) {
                        errorMessage =
                            "Network error. Please check your connection.";
                    }

                    showStatus(status, `X ${errorMessage}`, false);
                } finally {
                    btnText.style.display = "inline";
                    loading.style.display = "none";
                    submitBtn.disabled = false;
                }
            });

            suggestionForm.addEventListener("submit", async function (e) {
                e.preventDefault();

                const submitBtn = document.getElementById("suggestionSubmit");
                const btnText = document.getElementById("suggestionBtnText");
                const loading = document.getElementById("suggestionLoading");
                const status = document.getElementById("suggestionStatus");

                const suggestionType =
                    document.getElementById("suggestionType").value;
                const suggestionText = document
                    .getElementById("suggestionText")
                    .value.trim();

                if (!suggestionType) {
                    showStatus(
                        status,
                        "Please select a suggestion type",
                        false,
                    );
                    return;
                }

                if (!suggestionText || suggestionText.length < 10) {
                    showStatus(
                        status,
                        "Please provide a detailed suggestion (at least 10 characters)",
                        false,
                    );
                    return;
                }

                btnText.style.display = "none";
                loading.style.display = "inline-block";
                submitBtn.disabled = true;
                status.style.display = "none";

                try {
                    const formData = {
                        suggestionType: suggestionType,
                        suggestionText: suggestionText,
                    };
                    console.log("Sending suggestion request:", formData);
                    console.log("API URL:", `${API_BASE_URL}/api/suggestion`);

                    const response = await fetch(
                        `${API_BASE_URL}/api/suggestion`,
                        {
                            method: "POST",
                            headers: {
                                "Content-Type": "application/json",
                            },
                            body: JSON.stringify(formData),
                            mode: "cors",
                            credentials: "omit",
                        },
                    );

                    console.log("Response status:", response.status);

                    const result = await response.json();
                    console.log("Response data:", result);

                    if (response.ok) {
                        showStatus(
                            status,
                            "✓ Suggestion submitted successfully! Thank you for your feedback.",
                            true,
                        );
                        suggestionForm.reset();

                        setTimeout(() => {
                            status.style.display = "none";
                        }, 5000);
                    } else {
                        throw new Error(
                            result.error ||
                                result.details ||
                                "Submission failed",
                        );
                    }
                } catch (error) {
                    console.error("Error:", error);

                    let errorMessage = error.message;
                    if (error.message.includes("Failed to fetch")) {
                        errorMessage =
                            "Cannot connect to server. Please check your internet connection or try again later.";
                    } else if (error.message.includes("NetworkError")) {
                        errorMessage =
                            "Network error. Please check your connection.";
                    }

                    showStatus(status, `X ${errorMessage}`, false);
                } finally {
                    btnText.style.display = "inline";
                    loading.style.display = "none";
                    submitBtn.disabled = false;
                }
            });

            async function testAPIConnection() {
                try {
                    const response = await fetch(`${API_BASE_URL}/health`, {
                        method: "GET",
                        mode: "cors",
                    });

                    if (response.ok) {
                        console.log("✓ Backend API is reachable");
                    } else {
                        console.warn(
                            " Backend API returned non-OK status:",
                            response.status,
                        );
                    }
                } catch (error) {
                    console.error(
                        "X Cannot connect to backend API:",
                        error.message,
                    );
                    console.log(
                        "Make sure to update API_BASE_URL with your Render URL",
                    );
                }
            }

            setTimeout(testAPIConnection, 1000);
        });
    </script>
</Layout>
