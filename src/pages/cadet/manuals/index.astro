---
import Layout from "../../../layouts/Layout.astro";

// Style & JS
import "../../../style/manuals.css";
---
<Layout title="Manuals" disableHero>
<div class="BG555">
    <div class="container">
        <!-- Hero Section -->
        <div class="section-header">
            <h1 class="section-title">NJROTC Manuals</h1>
            <p class="section-subtitle">Essential resources for cadet training and development</p>
        </div>

        <!-- Navigation Links -->
        <div class="nav-links">
            <a class="nav-link" href="#CFM">BOB</a>
            <a class="nav-link" href="#CRM">CRM</a>
            <a class="nav-link" href="#NCDM">NCDM</a>
            <a class="nav-link" href="#NS1">NS1</a>
            <a class="nav-link" href="#NS2">NS2</a>
            <a class="nav-link" href="#NS3">NS3</a>
            <a class="nav-link" href="#NS4">NS4</a>
        </div>

        <!-- CFM Section -->
        <div class="manual-section" id="CFM">
            <div class="section-header">
                <h2 class="section-title">CADET FIELD MANUAL</h2>
                <p class="section-subtitle">(AKA YOUR B.O.B.) - 11th and 12th Editions</p>
            </div>
            <div class="pdf-grid">
                <div class="pdf-card">
                    <div class="pdf-preview">
                        <iframe src="/PDFs/CFM 11th Edition revised-title.pdf#toolbar=0" scrolling="no"></iframe>
                    </div>
                    <div class="pdf-info">
                        <h3 class="pdf-title">CADET FIELD MANUAL 11TH</h3>
                        <div class="pdf-actions">
                            <a target="_blank" href="/PDFs/CFM 11th Edition revised.pdf" class="pdf-btn">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M7 17h10v2H7zm-4 4h18v2H3z"/>
                                    <path d="M12 2L4 10h5v8h6v-8h5L12 2z"/>
                                </svg>
                                Fullscreen
                            </a>
                            <a target="_blank" href="/PDFs/CFM 11th Edition revised.pdf" download class="pdf-btn">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/>
                                </svg>
                                Download
                            </a>
                        </div>
                    </div>
                </div>

                <div class="pdf-card">
                    <div class="pdf-preview">
                        <iframe src="/PDFs/CFM 12th Edition Master Draft (0509-LP-002-6028) 17 APR 2024-title.pdf#toolbar=0" scrolling="no"></iframe>
